# Copy this file to .env.local and fill in your values
# JSON file-based storage configuration
# The database file will be stored in .data/domainshepherd.json by default
# Optionally customize the database directory:
# SQLITE_DB_DIR=/path/to/data/directory

# Probe batch concurrency (applies to web API and Tauri invoke path via shared frontend config)
# Optional; default is 10. Allowed range: 1..50
# NEXT_PUBLIC_PROBE_BATCH_CONCURRENCY=10

# Probe auto-retry max attempts per domain
# Optional; default is 2. Allowed range: 1..5
# NEXT_PUBLIC_PROBE_MAX_ATTEMPTS=2


