{
  "name": "domainshepherd",
  "version": "0.1.5",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-next-with-git-meta.mjs dev",
    "dev:tauri": "node scripts/run-next-with-git-meta.mjs dev -p 3001",
    "build": "node scripts/run-next-with-git-meta.mjs build",
    "build:portable": "node scripts/build-portable.mjs",
    "start": "next start",
    "lint": "eslint src",
    "test": "node --test --import tsx tests/probe-requirements.test.ts",
    "test:requirements": "node --test --import tsx tests/probe-requirements.test.ts",
    "test:parity": "cargo build --quiet --manifest-path src-tauri/Cargo.toml --bin parity_probe && node --test --import tsx tests/probe-parity.test.ts",
    "tauri": "tauri",
    "tauri:dev": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri dev",
    "tauri:build": "set PATH=%USERPROFILE%\\.cargo\\bin;%PATH%&& tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.4.0",
    "next": "^16.2.6",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "typescript-eslint": "^8.59.3"
  }
}
