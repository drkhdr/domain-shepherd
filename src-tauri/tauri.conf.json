  {
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "Domain Shepherd",
    "version": "0.1.0",
    "identifier": "com.dirkheider.domainshepherd",
    "build": {
      "frontendDist": "../out",
      "devUrl": "http://localhost:3001",
      "beforeDevCommand": "npm run dev:tauri",
      "beforeBuildCommand": "npm run build:portable"
    },
    "app": {
      "windows": [
        {
          "title": "Domain Shepherd",
          "width": 1600,
          "height": 900,
          "resizable": true,
          "fullscreen": false
        }
      ],
      "security": {
        "csp": null
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "android": {
        "debugApplicationIdSuffix": ".debug"
      }
    }
  }
